# Database
DATABASE_URL="postgresql://user:password@localhost:5432/swapcard_clone"

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Email Provider (for magic links)
# For development: Leave empty - magic links will be logged to console
# For production: Configure an SMTP server (e.g., Resend, SendGrid, Postmark)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@vitalistbay.com"

# Optional: OAuth providers (if you want to add Google, GitHub, etc.)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
